<node id="ent:experiment_1_rc_coupled_common_emitter_amplifier">
  <data key="d0">ENTITY</data>
  <data key="d4">Experiment 1: RC Coupled Common Emitter Amplifier</data>
  <data key="d5">EXPERIMENT</data>
  <data key="d6">["EXPERIMENT 1: RC COUPLED COMMON EMITTER AMPLIFIER", "EXPERIMENT 1: RC COUPLED COMMON EMITTER AMPLIFIER USING\nBC547"]</data>
  <data key="d7">["The primary subject of the document, an experiment to design and study a single stage RC coupled common emitter amplifier using a BC547 transistor. The aim is to determine its voltage gain, input impedance, frequency response, and bandwidth."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:bc547_transistor">
  <data key="d0">ENTITY</data>
  <data key="d4">BC547 Transistor</data>
  <data key="d5">COMPONENT</data>
  <data key="d6">["BC547 transistor"]</data>
  <data key="d7">["The specific NPN bipolar junction transistor used as the active amplifying component in the common emitter amplifier circuit."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:voltage_gain_av">
  <data key="d0">ENTITY</data>
  <data key="d4">Voltage Gain (Av)</data>
  <data key="d5">PARAMETER</data>
  <data key="d6">["Voltage gain", "voltage gain"]</data>
  <data key="d7">["A primary parameter to be determined in the experiment, representing the ratio of the output voltage to the input voltage (Av = Vout / Vin). The experiment measured a mid-frequency gain of approximately 28.4."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:input_impedance_rin">
  <data key="d0">ENTITY</data>
  <data key="d4">Input Impedance (Rin)</data>
  <data key="d5">PARAMETER</data>
  <data key="d6">["input impedance = 2 kΩ"]</data>
  <data key="d7">["A parameter to be determined for the amplifier. The design target for the input impedance is specified as 2 kΩ."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:frequency_response">
  <data key="d0">ENTITY</data>
  <data key="d4">Frequency Response</data>
  <data key="d5">PARAMETER</data>
  <data key="d6">["frequency response"]</data>
  <data key="d7">["A key characteristic to be studied, describing how the amplifier's gain varies with the frequency of the input signal. The response shows low gain at low/high frequencies and constant gain at mid-frequencies."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:bandwidth">
  <data key="d0">ENTITY</data>
  <data key="d4">Bandwidth</data>
  <data key="d5">PARAMETER</data>
  <data key="d6">["Bandwidth", "bandwidth"]</data>
  <data key="d7">["A parameter to be determined, representing the range of frequencies over which the amplifier's gain is within a specified range of its maximum value. The calculated bandwidth is approximately 400 kHz."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
