</node>
<node id="ent:rc_coupled_amplifier">
  <data key="d0">ENTITY</data>
  <data key="d4">RC Coupled Amplifier</data>
  <data key="d5">CIRCUIT_TOPOLOGY</data>
  <data key="d6">["RC coupled amplifier"]</data>
  <data key="d7">["A type of voltage amplifier that uses resistors and capacitors to couple the AC signal between stages while blocking DC, preventing biasing interference."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:coupling_capacitors">
  <data key="d0">ENTITY</data>
  <data key="d4">Coupling Capacitors</data>
  <data key="d5">COMPONENT_TYPE</data>
  <data key="d6">["coupling capacitors"]</data>
  <data key="d7">["Capacitors used to pass the AC signal from the input source to the amplifier's input and from the amplifier's output to the load, while blocking DC voltage."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:common_emitter_amplifier">
  <data key="d0">ENTITY</data>
  <data key="d4">Common Emitter Amplifier</data>
  <data key="d5">CIRCUIT_TOPOLOGY</data>
  <data key="d6">["COMMON EMITTER AMPLIFIER", "common emitter amplifier"]</data>
  <data key="d7">["A specific transistor amplifier configuration where the emitter terminal is common to both the input and output circuits. It is characterized by high voltage gain and a 180-degree phase inversion."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:emitter_terminal">
  <data key="d0">ENTITY</data>
  <data key="d4">Emitter Terminal</data>
  <data key="d5">COMPONENT_PART</data>
  <data key="d6">["emitter terminal"]</data>
  <data key="d7">["One of the three terminals of the BC547 transistor. In this configuration, it is common to both input and output."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:base_terminal">
  <data key="d0">ENTITY</data>
  <data key="d4">Base Terminal</data>
  <data key="d5">COMPONENT_PART</data>
  <data key="d6">["Base", "base"]</data>
  <data key="d7">["One of the three terminals of the BC547 transistor. The input signal is applied to this terminal."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:collector_terminal">
  <data key="d0">ENTITY</data>
  <data key="d4">Collector Terminal</data>
  <data key="d5">COMPONENT_PART</data>
  <data key="d6">["Collector", "collector"]</data>
  <data key="d7">["One of the three terminals of the BC547 transistor. The amplified output signal is taken from this terminal."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:phase_inversion_of_180_degrees">
  <data key="d0">ENTITY</data>
  <data key="d4">Phase Inversion of 180 degrees</data>
  <data key="d5">CHARACTERISTIC</data>
  <data key="d6">["phase\ninversion of 180 degrees"]</data>
  <data key="d7">["A characteristic of the common emitter amplifier where the output signal is 180 degrees out of phase with the input signal."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:voltage_divider_bias_network">
  <data key="d0">ENTITY</data>
  <data key="d4">Voltage Divider Bias Network</data>
  <data key="d5">CIRCUIT_TOPOLOGY</data>
  <data key="d6">["voltage divider bias network"]</data>
  <data key="d7">["A biasing circuit, using resistors R1 (100 kΩ) and R2 (18 kΩ), designed to set a stable DC operating point (Q-point) for the transistor in the active region."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:transistor_operation_in_active_region">
  <data key="d0">ENTITY</data>
  <data key="d4">Transistor Operation in Active Region</data>
  <data key="d5">OPERATING_MODE</data>
  <data key="d6">["active region"]</data>
  <data key="d7">["The desired operating mode for the transistor to function as an amplifier, where a small change in base voltage causes a large, proportional change in collector current."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:collector_resistor_rc">
  <data key="d0">ENTITY</data>
  <data key="d4">Collector Resistor (Rc)</data>
  <data key="d5">COMPONENT</data>
  <data key="d6">["Collector resistor", "collector resistor"]</data>
  <data key="d7">["A resistor connected to the collector terminal, used to convert the amplified variations in collector current into a corresponding output voltage variation. Its value is 1.5 kΩ."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:amplifier_gain_dependence_on_frequency">
  <data key="d0">ENTITY</data>
  <data key="d4">Amplifier Gain Dependence on Frequency</data>
  <data key="d5">CONCEPT</data>
  <data key="d6">["gain of an RC coupled amplifier depends on frequency"]</data>
  <data key="d7">["The principle that the voltage gain of an RC coupled amplifier is not constant across all frequencies. It is low at very low and very high frequencies and maximum in a mid-frequency range."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:low_frequency_range">
  <data key="d0">ENTITY</data>
  <data key="d4">Low-Frequency Range</data>
  <data key="d5">FREQUENCY_RANGE</data>
  <data key="d6">["low frequencies"]</data>
  <data key="d7">["The range of frequencies where the amplifier gain is reduced due to the high reactance of coupling and bypass capacitors."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:mid_frequency_range">
  <data key="d0">ENTITY</data>
  <data key="d4">Mid-Frequency Range</data>
  <data key="d5">FREQUENCY_RANGE</data>
  <data key="d6">["mid\nfrequencies", "mid-frequency range"]</data>
  <data key="d7">["The range of frequencies where the amplifier gain is nearly constant and at its maximum value. In the experiment, this is observed from approximately 500 Hz to 200 kHz."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:high_frequency_range">
  <data key="d0">ENTITY</data>
  <data key="d4">High-Frequency Range</data>
  <data key="d5">FREQUENCY_RANGE</data>
  <data key="d6">["high frequencies"]</data>
  <data key="d7">["The range of frequencies where the amplifier gain decreases due to the effects of internal transistor capacitances and the Miller effect."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:high_reactance_of_capacitors">
  <data key="d0">ENTITY</data>
  <data key="d4">High Reactance of Capacitors</data>
  <data key="d5">PARAMETER</data>
  <data key="d6">["reactance of coupling and bypass capacitors is high"]</data>
  <data key="d7">["At low frequencies, the impedance (reactance) of coupling and bypass capacitors becomes significant, which causes a voltage drop and reduces the overall gain of the amplifier."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:internal_transistor_capacitances">
  <data key="d0">ENTITY</data>
  <data key="d4">Internal Transistor Capacitances</data>
  <data key="d5">PARAMETER</data>
  <data key="d6">["internal transistor capacitances"]</data>
  <data key="d7">["Parasitic capacitances inherent within the transistor structure (e.g., between base-collector, base-emitter) that limit the amplifier's performance at high frequencies."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
<node id="ent:miller_effect">
  <data key="d0">ENTITY</data>
  <data key="d4">Miller Effect</data>
  <data key="d5">CONCEPT</data>
  <data key="d6">["Miller effect"]</data>
  <data key="d7">["An effect in inverting amplifiers where the capacitance between the input and output terminals appears as a much larger capacitance at the input, limiting the high-frequency response."]</data>
  <data key="d8">["tmp_1771604354512_aiclab1_1"]</data>
  <data key="d9">high</data>
</node>
