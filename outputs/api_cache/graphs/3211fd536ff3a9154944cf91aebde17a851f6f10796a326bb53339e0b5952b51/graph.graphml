  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">provided that the first flood damage occurs prior to the date and time of the expiration of this Policy.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:each_loss_caused_by_flood_and_all_losses_caused_by_flood_within_a_seventy_two_72_hours_period" target="ent:a_single_loss" id="e:rel:0704107d75dc5ce6">
  <data key="d26">SHALL_BE_DEEMED_TO_CONSTITUTE</data>
