  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">To indemnify The Insured in respect of Loss of Gross Profits the loss actually sustained during the Indemnity Period resulting from a reduction in turnover including any increased cost of working due to an interruption of The Insured’s business following loss or damage to any property and / or assets insured and recoverable under Section I, &amp; II.</data>
  <data key="d29">oneshot</data>
</edge>
