<edge source="ent:in_the_event_of_loss_and_or_damage_claim_or_suit_which_may_reasonably_give_rise_to_a_claim_under_this_policy_of_insurance" target="ent:give_to_the_insurer_as_soon_as_practicable_but_not_later_than_30_days_after_the_occurrence_of_the_event_written_notice" id="e:rel:a4bbcb1b51d8ca03">
  <data key="d26">THE_INSURED_SHALL</data>
