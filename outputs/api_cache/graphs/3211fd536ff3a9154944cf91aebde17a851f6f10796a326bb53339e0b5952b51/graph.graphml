  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_section_section_i" target="ent:any_faults_or_defects_existing_at_the_time_of_commencement_of_this_policy_of_insurance_of_which_the_insured_or_his_representatives_were_or_ought_reasonably_to_have_been_aware_irrespective_of_whether_such_faults_or_defects_were_known_to_the_insurer_or_not" id="e:rel:f77514c3d1713689">
