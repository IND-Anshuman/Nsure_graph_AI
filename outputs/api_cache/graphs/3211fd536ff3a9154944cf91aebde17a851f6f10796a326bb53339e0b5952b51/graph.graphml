  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:all_rights_against_carriers_bailees_or_other_third_parties_are_properly_preserved_and_exercised" id="e:rel:932c482ad5044127">
  <data key="d26">SHALL_ENSURE_THAT</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">c. ensure that all rights against carriers, bailees or other third parties are properly preserved and exercised;</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:the_insurer" id="e:rel:9df5ea8a8dc67704">
  <data key="d26">SHALL_COOPERATE_WITH</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">d. co-operate with the Insurer, and, upon the Insurer’s request, assist in making settlements, in the conduct of suits and in enforcing any right of contribution or indemnity against any person or organisation who may be liable to the Insured because of property damage with respect to which insurance is afforded under this Policy, and the Insured shall attend hearings, and trials and assist in securing and giving evidence and obtaining the attendance of witnesses.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:making_settlements_in_the_conduct_of_suits_and_in_enforcing_any_right_of_contribution_or_indemnity_against_any_person_or_organisation_who_may_be_liable_to_the_insured_because_of_property_damage" id="e:rel:6b24d88b44c4093a">
  <data key="d26">SHALL_ASSIST_IN</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">d. co-operate with the Insurer, and, upon the Insurer’s request, assist in making settlements, in the conduct of suits and in enforcing any right of contribution or indemnity against any person or organisation who may be liable to the Insured because of property damage with respect to which insurance is afforded under this Policy, and the Insured shall attend hearings, and trials and assist in securing and giving evidence and obtaining the attendance of witnesses.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:hearings_and_trials_and_assist_in_securing_and_giving_evidence_and_obtaining_the_attendance_of_witnesses" id="e:rel:3e5411428ffdeee3">
  <data key="d26">SHALL_ATTEND</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">d. co-operate with the Insurer, and, upon the Insurer’s request, assist in making settlements, in the conduct of suits and in enforcing any right of contribution or indemnity against any person or organisation who may be liable to the Insured because of property damage with respect to which insurance is afforded under this Policy, and the Insured shall attend hearings, and trials and assist in securing and giving evidence and obtaining the attendance of witnesses.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:any_payment_assume_any_obligation_or_incur_any_expenses_except_at_his_own_cost" id="e:rel:860e35619540f022">
  <data key="d26">SHALL_NOT_VOLUNTARILY_MAKE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">e. The Insured shall not, except at his own cost, voluntarily make any payment, assume any obligation, or incur any expenses.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:all_such_things_as_may_be_practicable_to_establish_the_cause_and_extent_of_the_loss_or_damage" id="e:rel:e5ead8b09be5200d">
  <data key="d26">SHALL_DO_AND_CONCUR_IN_DOING_AND_PERMIT_TO_BE_DO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">f. do and concur in doing and permit to be done all such things as may be practicable to establish the cause and extent of the loss or damage</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:all_parts_affected_and_make_them_available_for_inspection_by_the_insurer_as_long_as_the_insurer_may_require" id="e:rel:75799b21c0959ba1">
  <data key="d26">SHALL_PRESERVE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">g. preserve all parts affected and make them available for inspection by the Insurer as long as the Insurer may require</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:any_information_and_documentary_evidence_that_the_insurer_may_require_together_with_if_required_a_statutory_declaration_of_the_truth_of_the_claim" id="e:rel:5ccdb1c2d1b8a0e8">
  <data key="d26">SHALL_FURNISH</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">h. furnish any information and documentary evidence that the Insurer may require together with, if required, a statutory declaration of the truth of the claim</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:the_police_authorities_of_loss_or_damage_due_to_major_fire_theft_or_burglary_or_actions_by_any_malicious_person" id="e:rel:47207236191aea21">
  <data key="d26">SHALL_INFORM</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">i. inform the police authorities of loss or damage due to major fire, theft or burglary or actions by any malicious person and render all reasonable assistance to the police authorities</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:all_reasonable_assistance_to_the_police_authorities" id="e:rel:85ce107ec190d021">
  <data key="d26">SHALL_RENDER</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">i. inform the police authorities of loss or damage due to major fire, theft or burglary or actions by any malicious person and render all reasonable assistance to the police authorities</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:abandon_any_property_to_the_insurer_whether_taken_possession_of_by_the_insurer_or_not" id="e:rel:6f14127abe31b580">
  <data key="d26">SHALL_NOT_IN_ANY_CASE_BE_ENTITLED_TO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insured shall not in any case be entitled to abandon any property to the Insurer whether taken possession of by the Insurer or not.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:the_possession_of_all_goods_involved_in_any_loss_under_this_policy" id="e:rel:78a5de7807e43ea7">
  <data key="d26">SHALL_HAVE_FULL_RIGHT_TO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insured shall have full right to the possession of all goods involved in any loss under this Policy and retain control of all damaged goods.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:control_of_all_damaged_goods" id="e:rel:0f32163941f9b8fb">
  <data key="d26">RETAINS</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insured shall have full right to the possession of all goods involved in any loss under this Policy and retain control of all damaged goods.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:insurers_any_salvage_obtained_by_the_insured_on_sale_or_other_disposition_of_such_goods" id="e:rel:5e32baebe5f411c7">
  <data key="d26">SHALL_ALLOW</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">but the Insured shall allow Insurers any salvage obtained by the Insured on sale or other disposition of such goods.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:the_rateable_proportion_of_the_loss_accordingly" id="e:rel:694e0fd4ae59f39c">
  <data key="d26">SHALL_BEAR</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">and shall bear the rateable proportion of the loss accordingly.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:insurance_in_respect_of_the_amounts_of_the_deductibles_stated_in_the_schedule" id="e:rel:4e37431150273215">
  <data key="d26">SHALL_NOT_EFFECT</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">Warranted that the Insured shall not effect insurance in respect of the amounts of the Deductibles stated in the Schedule.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:the_insurer_his_full_co_operation_in_pursuing_such_claim_or_legal_proceedings" id="e:rel:b023af1300185588">
  <data key="d26">SHALL_PROVIDE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">and the Insured shall provide the Insurer his full co-operation in pursuing such claim or legal proceedings.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:all_actions_that_may_be_necessary_or_required_by_the_insurer_in_the_interest_of_any_rights_or_remedies_or_for_the_purpose_of_obtaining_relief_or_indemnity_to_which_the_insurer_is_or_would_become_entitled_or_which_is_or_would_be_subrogated_to_him_upon_indemnification_or_rectification_of_any_loss_or_damage_under_this_policy_of_insurance" id="e:rel:8abd665aa5653f40">
  <data key="d26">SHALL_AT_THE_INSURERS_EXPENSE_DO_AND_CONCUR_IN_D</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insured shall at the Insurer’s expense do and concur in doing and permit to be done all actions that may be necessary or required by the Insurer in the interest of any rights or remedies or for the purpose of obtaining relief or indemnity to which the Insurer is or would become entitled or which is or would be subrogated to him upon indemnification or rectification of any loss or damage under this Policy of Insurance, regardless of whether such action is or becomes necessary or required before or after the Insured’s indemnification by the Insurer.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:right_to_make_inspections" target="ent:undertaking_to_determine_or_warrant_property_operations_are_safe_healthy_or_compliant_with_law" id="e:rel:e91cd19c2a53c05d">
  <data key="d26">SHALL_NOT_CONSTITUTE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">Neither the right to make inspections nor the making thereof nor any advice or report resulting therefrom shall constitute an undertaking on behalf or for the benefit of The Insured or others to determine or warrant that such property or operations are safe and healthy or are in compliance with a law, rule or regulation.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:required_cover" target="ent:the_insured_until_premium_is_paid_and_realised_by_the_insurer" id="e:rel:0864099bdcabe999">
  <data key="d26">SHALL_NOT_BE_AVAILABLE_TO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The required cover for which Premium was sought shall not be available to the Insured until such date that the Premium is paid by the Insuring Party and realised by the Insurer</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:payment_of_the_premium" target="ent:the_insurer_s_liability_towards_any_insured_party_under_any_section_of_this_policy_of_insurance" id="e:rel:3ef5fd849e246f20">
  <data key="d26">IS_A_CONDITION_PRECEDENT_TO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">it is understood that payment of the Premium is a condition precedent to The Insurer’s liability towards any Insured Party under any Section of this Policy of Insurance.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:cover_as_agreed_under_this_policy" target="ent:the_date_of_payment_of_the_required_premium" id="e:rel:960da04b2194bef0">
  <data key="d26">WOULD_INCEPT_FROM</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">Cover as agreed under this Policy would incept from the date of payment of the required Premium.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:sum_s_insured_specified_in_the_schedule" target="ent:the_new_replacement_value_of_such_property" id="e:rel:3c49338b4d3d9b90">
  <data key="d26">SHALL_NOT_BE_LESS_THAN</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">It is a requirement of this Policy of Insurance that the sum(s) insured specified in The Schedule in respect of the Property Insured shall not be less than the New Replacement Value of such property.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_policy" target="ent:the_written_request_of_the_insuring_party_with_seven_days_notice" id="e:rel:64bf3203f858dfcb">
  <data key="d26">MAY_BE_TERMINATED_AT_ANY_TIME_AT</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">This Policy may be terminated at any time at the written request of the Insuring Party with seven days notice.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_policy" target="ent:loss_damage_cost_or_expense_of_whatsoever_nature_directly_or_indirectly_caused_by_resulting_from_or_in_connection_with_political_risks" id="e:rel:48ba9d98835c51c9">
  <data key="d26">EXCLUDES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">This Policy excludes loss, damage, cost or expense of whatsoever nature directly or indirectly caused by, resulting from or in connection with any of the following regardless of any other cause or event contributing concurrently or in any other sequence to the loss: 1. Political Risks Exclusion</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_policy" target="ent:loss_damage_cost_or_expense_directly_or_indirectly_caused_by_resulting_from_or_in_connection_with_any_act_of_terrorism" id="e:rel:2045d6227a608538">
  <data key="d26">EXCLUDES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">This Policy excludes loss, damage, cost or expense of whatsoever nature directly or indirectly caused by, resulting from or in connection with any act of terrorism regardless of any other cause or event contributing concurrently or in any other sequence to the loss.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_policy" target="ent:loss_damage_cost_or_expense_directly_or_indirectly_caused_by_resulting_from_or_in_connection_with_radioactive_contamination" id="e:rel:c0f4e8fc11f0435e">
  <data key="d26">EXCLUDES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">2. Radioactive Contamination Nuclear reaction or nuclear radiation or radioactive contamination, all whether controlled or uncontrolled, and whether such loss be direct or indirect, proximate or remote, or be in whole or in part caused by, contributed aggravated by the peril(s) insured hereunder, including the following:</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_policy" target="ent:any_act_of_default_committed_by_the_insured_or_its_representatives" id="e:rel:3c149d941e22633d">
  <data key="d26">EXCLUDES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">3. Act of default Any Act of default committed by the insured or its Representatives.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_policy" target="ent:the_amounts_stated_in_the_schedule_as_being_the_deductibles_time_excess" id="e:rel:9cc7ba5ff9eee341">
  <data key="d26">EXCLUDES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">4. Deductibles The amounts stated in The Schedule as being the Deductibles, Time Excess..</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_policy" target="ent:the_amounts_of_the_deductibles_stated_in_the_schedule_in_respect_of_each_and_every_loss" id="e:rel:608e95f70a635b00">
  <data key="d26">DOES_NOT_COVER</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">This Policy does not cover the amounts of the Deductibles stated in the Schedule in respect of each and every loss as ascertained after the application of all other terms and conditions of the Policy including any underinsurance.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_policy" target="ent:indian_laws" id="e:rel:fcb58a6fa78bd992">
  <data key="d26">SHALL_BE_CONSTRUED_ACCORDING_TO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">This Policy shall be construed according to INDIAN laws and The Insurers undertake to submit to the jurisdiction of INDIAN Courts in respect of any matter relating to or arising out of this Policy but nothing herein contained shall be held to detract from the force of the arbitration clause above.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_policy" target="comm_l0:4" id="e:comm_member:1165">
  <data key="d26">MEMBER_OF</data>
  <data key="d39">0</data>
  <data key="d40">4</data>
</edge>
<edge source="ent:termination_or_cancellation" target="ent:pro_rata_daily_return_of_premium_payable_to_the_insuring_party_for_the_unexpired_period" id="e:rel:41a0f73bf23262ad">
  <data key="d26">RESULTS_IN</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">In either case, pro-rata daily return of Premium shall be payable to The Insuring Party for the unexpired period from the date of termination.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:if_this_policy_should_expire_or_be_cancelled_while_an_insured_event_affecting_the_property_insured_is_in_progress" target="ent:the_entire_loss_had_occurred_prior_to_the_expiration_of_this_insurance" id="e:rel:d89f296b25b09239">
  <data key="d26">THE_INSURERS_ARE_RESPONSIBLE_AS_IF</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">If this Policy should expire or be cancelled while an insured event affecting the Property Insured is in progress, it is understood and agreed that Insurers, subject to all other terms, conditions and exclusions of this Policy, are responsible as if the entire loss had occurred prior to the expiration of this insurance.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:responsibility_for_loss_during_expiration_cancellation" target="ent:all_other_terms_conditions_and_exclusions_of_this_policy" id="e:rel:933e5d79d8d29298">
  <data key="d26">SUBJECT_TO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">subject to all other terms, conditions and exclusions of this Policy</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:responsibility_for_loss_during_expiration_cancellation" target="comm_l0:19" id="e:comm_member:1171">
  <data key="d26">MEMBER_OF</data>
  <data key="d39">0</data>
  <data key="d40">19</data>
</edge>
<edge source="ent:all_other_terms_conditions_and_exclusions_of_this_policy" target="comm_l0:19" id="e:comm_member:1172">
  <data key="d26">MEMBER_OF</data>
  <data key="d39">0</data>
  <data key="d40">19</data>
</edge>
<edge source="ent:if_an_insured_party_makes_any_claim_that_is_fraudulent_or_any_false_declaration_or_statement_in_support_thereof" target="ent:void_between_the_insurer_and_the_insured_party_making_such_a_claim" id="e:rel:f738734e5c24432e">
  <data key="d26">THIS_POLICY_OF_INSURANCE_SHALL_BECOME</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">If an Insured Party makes any claim that is fraudulent or any false declaration or statement in support thereof, this Policy of Insurance between the Insurer and the Insured Party making such a claim shall become void</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:if_an_insured_party_makes_any_claim_that_is_fraudulent_or_any_false_declaration_or_statement_in_support_thereof" target="ent:any_payment_hereunder_to_that_party" id="e:rel:55c941cbcee2841c">
  <data key="d26">THE_INSURER_SHALL_NOT_BE_LIABLE_TO_MAKE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">and The Insurer shall not be liable to make any payment hereunder to that party.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:if_the_policy_of_insurance_is_treated_as_void_due_to_fraud_false_declaration" target="ent:any_return_of_premium" id="e:rel:702e596f47e0cac5">
  <data key="d26">THE_INSURING_PARTY_SHALL_NOT_BE_ENTITLED_TO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">For the avoidance of doubt, the Insuring Party shall not be entitled to any return of Premium in the event that the Policy of Insurance is treated as void.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:if_there_be_any_material_mis_description_by_the_insured_or_any_one_acting_on_his_behalf_of_any_of_the_property_hereby_insured" target="ent:the_property_affected_by_any_such_mis_description" id="e:rel:3f157156c62a49f1">
  <data key="d26">THE_INSURER_SHALL_NOT_BE_LIABLE_UNDER_THIS_POLIC</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">If there be any material mis-description by the Insured or any one acting on his behalf of any of the property hereby insured, or of any place in which such property is contained, or of the business or Premises to which this insurance refers or any misrepresentation as to any fact material to be known for estimating the risk or any omission to state such fact, The Insurer shall not be liable under this Policy for the property affected by any such mis-description, misrepresentation or omission.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:if_there_be_any_misrepresentation_as_to_any_fact_material_to_be_known_for_estimating_the_risk_or_any_omission_to_state_such_fact" target="ent:the_property_affected_by_any_such_misrepresentation_or_omission" id="e:rel:d5c8161362f41666">
  <data key="d26">THE_INSURER_SHALL_NOT_BE_LIABLE_UNDER_THIS_POLIC</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">If there be any material mis-description by the Insured or any one acting on his behalf of any of the property hereby insured, or of any place in which such property is contained, or of the business or Premises to which this insurance refers or any misrepresentation as to any fact material to be known for estimating the risk or any omission to state such fact, The Insurer shall not be liable under this Policy for the property affected by any such mis-description, misrepresentation or omission.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:in_case_of_non_disclosure_of_material_facts_by_the_insured_in_the_proposal_form_personal_statement_declaration_and_connected_documents_or_any_material_information_having_been_withheld" target="ent:void" id="e:rel:34b632c514a81f1c">
  <data key="d26">THIS_POLICY_SHALL_BE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">It is also understood and agreed that this Policy shall be void and all premiums paid hereon shall be forfeited to the Company in case of non-disclosure of material facts by the Insured in the proposal form, personal statement, declaration and connected documents, or any material information having been withheld..</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:in_case_of_non_disclosure_of_material_facts" target="ent:forfeited_to_the_company" id="e:rel:a5e2cd6775e14c58">
  <data key="d26">ALL_PREMIUMS_PAID_HEREON_SHALL_BE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">all premiums paid hereon shall be forfeited to the Company in case of non-disclosure of material facts by the Insured</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:in_the_event_of_an_act_of_default_being_committed_by_an_insured_party_or_its_representatives" target="ent:any_amount_to_the_insured_party_under_this_policy_of_insurance" id="e:rel:fce0110a919a875c">
  <data key="d26">THE_INSURER_SHALL_NOT_BE_LIABLE_TO_PAY</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">In the event of an Act of default being committed by an Insured Party or its Representatives. The Insurer shall not be liable to pay any amount to the Insured Party under this Policy of Insurance.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:an_act_of_default_committed_by_one_insured_party_or_its_representatives" target="ent:the_entitlement_to_indemnity_of_any_other_insured_party_that_has_not_itself_and_whose_representatives_have_not_committed_an_act_of_default" id="e:rel:2d428a806e504654">
  <data key="d26">SHALL_NOT_PREJUDICE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">An Act of default committed by one Insured Party or its Representatives shall not prejudice the entitlement to indemnity of any other Insured Party that has not itself (and whose Representatives have not) committed an Act of default.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:in_the_event_of_the_insurer_refusing_to_indemnify_an_insured_party_as_a_result_of_any_act_of_default" target="ent:the_same_loss_or_damage_by_assuming_the_rights_or_obligations_of_the_insured_party_whose_claim_for_indemnity_the_insurer_has_refused_or_is_entitled_to_refuse" id="e:rel:5789d55c9cd1259d">
  <data key="d26">NO_OTHER_INSURED_PARTY_SHALL_BE_ENTITLED_TO_INDE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">In the event of the Insurer refusing to indemnify an Insured Party as a result of any Act of default no other Insured Party shall be entitled to indemnity in respect of the same loss or damage by assuming the rights or obligations of the Insured Party whose claim for indemnity the Insurer has refused or is entitled to refuse.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:in_the_event_of_an_act_of_default" target="ent:the_insured_party_any_loss_or_damage_it_may_have_suffered" id="e:rel:dfceaf3bad2632b9">
  <data key="d26">THE_INSURER_SHALL_BE_ENTITLED_TO_CLAIM_FROM</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">In the event of an Act of default The Insurer shall be entitled to claim from the Insured Party any loss or damage it may have suffered including, without limitation, any sums it may have paid to any other Insured Party as a result of any loss or damage caused or contributed to by the Insured Party or its Representatives committing an Act of default.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:any_party_named_as_the_insured_in_any_section_of_this_policy_of_insurance" target="ent:the_insuring_party_of_any_material_change_in_risk_of_which_it_is_aware_or_ought_reasonably_to_be_aware" id="e:rel:e64f8d572c5d7903">
  <data key="d26">SHALL_NOTIFY</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">As soon as is reasonably possible, any party named as the Insured in any Section of this Policy of Insurance shall notify the Insuring Party of any Material change in risk of which it is aware or ought reasonably to be aware</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:any_party_named_as_the_insured_in_any_section_of_this_policy_of_insurance" target="ent:at_its_own_expense_any_additional_precautions_that_may_be_necessary_to_prevent_loss_or_damage_occurring_to_the_property_insured_as_a_result_of_such_material_change_in_risk" id="e:rel:abea42dd60870bab">
  <data key="d26">SHALL_TAKE_OR_CAUSE_TO_BE_TAKEN</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">and shall take or cause to be taken at its own expense any additional precautions that may be necessary to prevent loss or damage occurring to the Property Insured as a result of such Material change in risk.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insuring_party" target="ent:the_insurer_in_writing_upon_receipt_of_any_notice_from_the_insured" id="e:rel:a6f956ab7c6e1fff">
  <data key="d26">SHALL_IMMEDIATELY_NOTIFY</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insuring Party shall immediately notify the Insurer in writing upon receipt of any notice from the Insured.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:if_the_insurer_has_agreed_to_the_material_change_in_risk" target="ent:adjusted_by_the_insurer_to_reflect_the_material_change_in_risk" id="e:rel:a185475ac0000cac">
  <data key="d26">THE_SCOPE_OF_COVER_AND_PREMIUM_SHALL_BE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">in which case the scope of cover and Premium shall, if necessary, be adjusted by the Insurer to reflect the Material change in risk.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:it_is_a_condition_of_this_policy_that_the_insured" target="ent:all_reasonable_steps_to_inspect_and_maintain_the_property_insured" id="e:rel:b07d4ea146c935fd">
  <data key="d26">TAKES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">It is a condition of this Policy that the Insured takes all reasonable steps to inspect and maintain the Property Insured.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:any_plant_machinery_or_equipment_forming_the_property_insured" target="ent:the_recommendations_of_the_suppliers_or_manufacturers_of_such_plant_machinery_or_equipment" id="e:rel:25036617f371076b">
  <data key="d26">SHALL_BE_INSPECTED_AND_MAINTAINED_IN_ACCORDANCE_</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">Any plant, machinery or equipment forming the Property Insured shall be inspected and maintained in accordance with the recommendations of the suppliers or manufacturers of such plant, machinery or equipment.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:such_inspection_and_maintenance" target="ent:safety_checks_preventive_inspection_and_maintenance_rectification_of_loss_or_damage_or_faults_arising_from_normal_operation_or_wear_and_tear_as_well_as_from_ageing_and_shall_also_include_the_repair_or_preventive_replacement_of_components_modules_or_parts" id="e:rel:d865458c0131c8ea">
  <data key="d26">SHALL_INCLUDE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">Such inspection and maintenance shall include safety checks, preventive inspection and maintenance, rectification of loss or damage or faults arising from normal operation or wear and tear as well as from ageing, and shall also include the repair or preventive replacement of components modules or parts.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:property_damage_covered_under_this_agreement" target="ent:physical_damage_to_the_substance_of_property" id="e:rel:1d04fc0f0b011f42">
  <data key="d26">SHALL_MEAN</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">Property damage covered under this Agreement shall mean physical damage to the substance of property.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:physical_damage_to_the_substance_of_property" target="ent:damage_to_data_or_software" id="e:rel:552d00e0b9a4248c">
  <data key="d26">SHALL_NOT_INCLUDE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">Physical damage to the substance of property shall not include damage to data or software, in particular any detrimental change in data, software or computer programs that is caused by a deletion, a corruption or a deformation of the original structure.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_following" target="ent:this_agreement" id="e:rel:c0df8a32eb3cddb4">
  <data key="d26">ARE_EXCLUDED_FROM</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:78</data>
  <data key="d38">Consequently the following are excluded from this Agreement:</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:loss_of_or_damage_to_data_or_software" target="ent:this_agreement" id="e:rel:b4e3cacaa6e5108b">
  <data key="d26">EXCLUDED_FROM</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">1. Loss of or damage to data or software, in particular any detrimental change in data, software or computer programs that is caused by a deletion, a corruption or a deformation of the original structure, and any business interruption losses resulting from such loss or damage.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:business_interruption_losses" target="ent:loss_of_or_damage_to_data_or_software" id="e:rel:e04256aba97a5a85">
  <data key="d26">RESULTING_FROM</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">and any business interruption losses resulting from such loss or damage.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:business_interruption_losses" target="ent:impairment_in_the_function_availability_range_of_use_or_accessibility_of_data_software_or_computer_programs" id="e:rel:6d0191cd905177a9">
  <data key="d26">RESULTING_FROM</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">and any business interruption losses resulting from such loss or damage.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:loss_or_damage_to_data_or_software_which_is_the_direct_consequence_of_insured_physical_damage_to_the_substance_of_property" target="ent:covered" id="e:rel:7679119b0f0145cd">
  <data key="d26">SHALL_BE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">Notwithstanding this exclusion, loss or damage to data or software which is the direct consequence of insured physical damage to the substance of property shall be covered.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:loss_or_damage_resulting_from_an_impairment_in_the_function_availability_range_of_use_or_accessibility_of_data_software_or_computer_programs" target="ent:this_agreement" id="e:rel:8c6c7aa6272e6a73">
  <data key="d26">EXCLUDED_FROM</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">2. Loss or damage resulting from an impairment in the function, availability, range of use or accessibility of data, software or computer programs, and any business interruption losses resulting from such loss or damage.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_company" target="ent:the_claim_under_this_policy_within_30_days_from_the_date_of_receipt_of_necessary_documents" id="e:rel:f5de940d564ef2e0">
  <data key="d26">WILL_SETTLE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Company will settle the Claim under this Policy within 30 days from the date of receipt of necessary documents required for assessing the Claim, provided the loss or damage occurred is covered under the terms and conditions of policy issued.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:in_the_event_that_the_company_decides_to_reject_a_claim_made_under_this_policy" target="ent:thirty_days_of_the_survey_report_or_the_additional_survey_report" id="e:rel:fae913b085614608">
  <data key="d26">THE_COMPANY_SHALL_DO_SO_WITHIN_A_PERIOD_OF</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">In the event that the Company decides to reject a Claim made under this Policy, the Company shall do so within a period of thirty days of the survey report or the additional survey report, as the case may be, in accordance with the provisions of Protection of Policyholders’ Interest Regulations 2002.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:claim_rejection" target="ent:the_provisions_of_protection_of_policyholders_interest_regulations_2002" id="e:rel:77a8171de59406a3">
  <data key="d26">IN_ACCORDANCE_WITH</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:83</data>
  <data key="d38">in accordance with the provisions of Protection of Policyholders’ Interest Regulations 2002.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:loss_damage_cost_or_expense_of_whatsoever_nature_directly_or_indirectly_caused_by_resulting_from_or_in_connection_with_political_risks" target="comm_l0:4" id="e:comm_member:1166">
  <data key="d26">MEMBER_OF</data>
  <data key="d39">0</data>
  <data key="d40">4</data>
</edge>
<edge source="ent:loss_damage_cost_or_expense_directly_or_indirectly_caused_by_resulting_from_or_in_connection_with_any_act_of_terrorism" target="comm_l0:4" id="e:comm_member:1167">
  <data key="d26">MEMBER_OF</data>
  <data key="d39">0</data>
  <data key="d40">4</data>
</edge>
<edge source="ent:act_of_terrorism_general_exclusions" target="ent:an_act_or_series_of_acts_including_but_not_limited_to_the_use_of_force_or_violence_and_or_the_threat_thereof_of_any_person_or_group_s_of_persons_whether_acting_alone_or_on_behalf_of_or_in_connection_with_any_organisation_s_or_government_s_or_unlawful_associations_recognized_under_unlawful_activities_prevention_amendment_act_2008_or_any_other_related_and_applicable_national_or_state_legislation_formulated_to_combat_unlawful_and_terrorist_activities_in_the_nation_for_the_time_being_in_force_committed_for_political_religious_ideological_or_similar_purposes_including_the_intention_to_influence_any_government_and_or_to_put_the_public_or_any_section_of_the_public_in_fear_for_such_purposes" id="e:rel:28480506d1a8c139">
  <data key="d26">MEANS</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">For the purpose of this exclusion, an act of terrorism means an act or series of acts, including but not limited to the use of force or violence and/or the threat thereof, of any person or group(s) of persons, whether acting alone or on behalf of or in connection with any organisation(s) or government(s), or unlawful associations, recognized under Unlawful Activities (Prevention) Amendment Act, 2008 or any other related and applicable national or state legislation formulated to combat unlawful and terrorist activities in the nation for the time being in force, committed for political, religious, ideological or similar purposes including the intention to influence any government and/or to put the public or any section of the public in fear for such purposes.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:act_of_terrorism_general_exclusions" target="ent:unlawful_activities_prevention_amendment_act_2008" id="e:rel:bec2a9f4d61d22bf">
  <data key="d26">RECOGNIZED_UNDER</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">unlawful associations, recognized under Unlawful Activities (Prevention) Amendment Act, 2008 or any other related and applicable national or state legislation formulated to combat unlawful and terrorist activities in the nation for the time being in force</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:this_exclusion_act_of_terrorism" target="ent:loss_damage_cost_or_expense_directly_or_indirectly_caused_by_resulting_from_or_in_connection_with_any_action_taken_in_controlling_preventing_suppressing_or_in_any_way_relating_to_the_above" id="e:rel:0ad171d98489365f">
  <data key="d26">ALSO_INCLUDES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">This exclusion also includes loss, damage, cost or expense of whatsoever nature directly or indirectly caused by, resulting from or in connection with any action taken in controlling, preventing, suppressing or in any way relating to the above.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:if_the_insurer_alleges_that_by_reason_of_this_exclusion_any_loss_damage_cost_or_expense_is_not_covered_by_this_policy" target="ent:the_insured" id="e:rel:293c7153e0e0ca78">
  <data key="d26">THE_BURDEN_OF_PROVING_THE_CONTRARY_SHALL_BE_UPON</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">If The Insurer alleges that by reason of this exclusion, any loss, damage, cost or expense is not covered by this Policy the burden of proving the contrary shall be upon the Insured.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:loss_damage_cost_or_expense_directly_or_indirectly_caused_by_resulting_from_or_in_connection_with_radioactive_contamination" target="comm_l0:4" id="e:comm_member:1168">
  <data key="d26">MEMBER_OF</data>
  <data key="d39">0</data>
  <data key="d40">4</data>
</edge>
<edge source="ent:radioactive_contamination_exclusion" target="ent:ionising_radiations_from_or_contamination_by_radioactivity_from_any_nuclear_fuel_or_from_any_nuclear_waste_or_from_combustion_of_nuclear_fuel" id="e:rel:f816e31c2dfaf6dd">
  <data key="d26">INCLUDES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">a. ionising radiations from or contamination by radioactivity from any nuclear fuel or from any nuclear waste or from combustion of nuclear fuel</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:radioactive_contamination_exclusion" target="ent:the_radioactive_toxic_explosive_or_other_hazardous_or_contaminating_properties_of_any_nuclear_installation_reactor_or_other_nuclear_assembly_or_nuclear_component_thereof" id="e:rel:4f9132024dd36dab">
  <data key="d26">INCLUDES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">b. the radioactive, toxic, explosive or other hazardous or contaminating properties of any nuclear installation, reactor or other nuclear assembly or nuclear component thereof</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:radioactive_contamination_exclusion" target="ent:any_weapon_of_war_missile_or_like_employing_atomic_or_nuclear_fission_and_or_fusion_or_other_like_reaction_or_radioactive_force_or_matter" id="e:rel:a8bd2afd2d6f992c">
  <data key="d26">INCLUDES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">c. any weapon of war, missile or like employing atomic or nuclear fission and / or fusion or other like reaction or radioactive force or matter</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:radioactive_contamination_exclusion" target="ent:nuclear_reaction_nuclear_radiation_or_radioactive_contamination" id="e:rel:fe485d79771be853">
  <data key="d26">INCLUDES</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:96</data>
  <data key="d38">d. nuclear reaction, nuclear radiation or radioactive contamination</data>
  <data key="d29">oneshot</data>
</edge>
