  <data key="d0">SENTENCE</data>
  <data key="d1">tmp_1769774017427_Large_Risk_-_Policy_Wordings</data>
  <data key="d3">109</data>
  <data key="d2">The Insurer shall reimburse the Insured for any charges properly and reasonably incurred in
pursuance of its duties in relation to clause (b) and (c) above in addition to any loss
recoverable under any Section of this Policy.</data>
</node>
