</edge>
<edge source="ent:this_section_section_i" target="ent:boiler_scale_incrustation_deterioration_settling_gradual_cracking_gradually_developing_deformation_or_distortion_scratching_of_painted_or_polished_surfaces" id="e:rel:417f50b21ec396c3">
