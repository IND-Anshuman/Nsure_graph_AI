  <data key="d26">SHALL_NOT_BE_LIABLE_TO_INDEMNIFY</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurer shall not be liable to indemnify the Insured or any Insured Party in respect of any occurrence happening prior to receipt of the Premium.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:this_policy_by_giving_the_insuring_party_not_less_than_30_days_prior_written_notice" id="e:rel:085a2113be82ed39">
  <data key="d26">MAY_CANCEL</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurer may cancel this Policy by giving The Insuring Party not less than 30 days prior written notice.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:any_loss_of_or_damage_to_property_insured_which_would_not_have_resulted_had_there_not_been_a_material_change_in_risk_unless_the_insurer_has_agreed_to_the_material_change_in_risk" id="e:rel:2a0e0e757b1306ac">
  <data key="d26">SHALL_NOT_BE_LIABLE_FOR</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurer shall not be liable for any loss of or damage to Property Insured which would not have resulted had there not been a Material change in risk unless The Insurer has agreed to the Material change in risk</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:the_insured_for_any_charges_properly_and_reasonably_incurred_in_pursuance_of_its_duties_in_relation_to_clause_b_and_c_above" id="e:rel:ad0cf6b3a51409a0">
  <data key="d26">SHALL_REIMBURSE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurer shall reimburse the Insured for any charges properly and reasonably incurred in pursuance of its duties in relation to clause (b) and (c) above in addition to any loss recoverable under any Section of this Policy.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:loss_or_damage_of_which_he_has_not_received_notification_within_30_days_of_its_occurrence" id="e:rel:29f0d98cb71a9b20">
  <data key="d26">SHALL_NOT_BE_LIABLE_FOR</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurer shall not be liable for loss or damage of which he has not received notification within 30 days of its occurrence.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:incur_any_liability_to_the_insured_or_diminish_its_rights_to_rely_upon_any_of_the_conditions_of_this_policy_in_answer_to_any_claim" id="e:rel:371f1a317e0a8491">
  <data key="d26">SHALL_NOT_BY_ANY_ACT_DONE_IN_THE_EXERCISE_OR_PUR</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">and the Insurer shall not by any act done in the exercise or purported exercise of its powers hereunder, incur any liability to the Insured or diminish its rights to rely upon any of the conditions of this Policy in answer to any claim.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:take_possession_of_such_salvage" id="e:rel:d5c2715d61b53a9a">
  <data key="d26">SHALL_HAVE_THE_RIGHT_TO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">the Insurer shall have the right to take possession of such salvage.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:any_losses_occurring_for_a_period_of_up_to_maximum_seventy_two_72_hours_after_the_expiration_of_this_policy_windstorm" id="e:rel:c549d7fa93bf98f8">
  <data key="d26">WILL_BE_LIABLE_FOR</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">However, The Insurer will be liable for any losses occurring for a period of up to maximum seventy-two (72) hours after the expiration of this Policy, provided that the first windstorm damage occurs prior to the date and time of the expiration of this Policy.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:any_loss_caused_by_an_earthquake_occurring_before_the_effective_date_and_time_of_this_policy" id="e:rel:5777d300824ffe81">
  <data key="d26">SHALL_NOT_BE_LIABLE_FOR</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurers shall not be liable for any loss caused by an earthquake occurring before the effective date and time of this Policy nor for any loss commencing after the expiration date and time of this Policy.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:any_loss_commencing_after_the_expiration_date_and_time_of_this_policy" id="e:rel:43d3016bd2f62648">
  <data key="d26">SHALL_NOT_BE_LIABLE_FOR</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurers shall not be liable for any loss caused by an earthquake occurring before the effective date and time of this Policy nor for any loss commencing after the expiration date and time of this Policy.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:any_loss_caused_by_flood_occurring_before_the_effective_date_and_time_of_this_policy" id="e:rel:b6fce60dc92ebead">
  <data key="d26">SHALL_NOT_BE_LIABLE_FOR</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurers shall not be liable for any loss caused by flood occurring before the effective date and time of this Policy nor for any loss commencing after the expiration date and time of this Policy.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:any_loss_or_damage_after_the_expiration_of_24_months_from_the_discovery_of_the_loss_or_damage" id="e:rel:9f425d0d2c5ffd0c">
  <data key="d26">IS_NOT_LIABLE_FOR</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurer is not liable for any loss or damage after the expiration of 24 months from the discovery of the loss or damage unless otherwise agreed in writing or the claim is submitted to a court or arbitration panel within the time prescribed therefore in accordance with applicable law.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:subrogated_to_all_the_insured_s_rights_of_recovery_against_any_other_person_firm_or_corporation_who_may_be_legally_or_contractually_liable_for_such_loss_damage_or_expenses_so_reimbursed_by_the_insurer" id="e:rel:b15af1e0e3c17464">
  <data key="d26">SHALL_UPON_REIMBURSEMENT_HEREUNDER_TO_THE_INSURE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurer shall upon reimbursement hereunder to the Insured of any loss, damage or expense be subrogated to all the Insured’s rights of recovery against any other person, firm or corporation who may be legally or contractually liable for such loss, damage or expenses so reimbursed by the Insurer, provided that</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:the_insured_such_money_or_monies_recovered_by_them_that_is_in_excess_of_the_loss_damage_or_expenses_so_received_by_the_insured" id="e:rel:da3825e7d8373f62">
  <data key="d26">SHALL_PASS_ON_TO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">- the Insurer shall pass on to the Insured such money or monies recovered by them that is in excess of the loss, damage or expenses so received by the Insured.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:all_insured_parties_provided_no_act_of_default_including_criminal_or_deliberate_or_fraudulent_acts_committed_by_any_insured_party_or_its_representatives_has_caused_any_loss_or_damage_to_any_other_insured_party" id="e:rel:02a9bf538b9590fb">
  <data key="d26">SHALL_WAIVE_ITS_RIGHTS_OF_SUBROGATION_AGAINST</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">the Insurer shall waive its rights of subrogation against all Insured Parties provided no Act of default including criminal or deliberate or fraudulent acts committed by any Insured Party or its Representatives has caused any loss or damage to any other Insured Party.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:any_parties_believed_responsible_for_loss_damage_or_expense_reimbursed_hereunder_in_the_name_of_the_insured" id="e:rel:bc68bef56ff1913b">
  <data key="d26">MAY_MAKE_A_CLAIM_UPON_AND_INSTITUTE_LEGAL_PROCEE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">It is agreed that the Insurers may make a claim upon and institute legal proceedings against any parties believed responsible for loss, damage or expense reimbursed hereunder in the name of the Insuredand the Insured shall provide the Insurer his full co-operation in pursuing such claim or legal proceedings.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:the_jurisdiction_of_indian_courts_in_respect_of_any_matter_relating_to_or_arising_out_of_this_policy" id="e:rel:26afb86ea3b7a306">
  <data key="d26">UNDERTAKE_TO_SUBMIT_TO</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">and The Insurers undertake to submit to the jurisdiction of INDIAN Courts in respect of any matter relating to or arising out of this Policy</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:the_insured_against_all_risks_of_fortuitous_and_accidental_physical_loss_or_damage_or_destruction_to_the_property_insured" id="e:rel:7a1c22743c026a1e">
  <data key="d26">AGREES_TO_INDEMNIFY</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurer agrees subject to the terms, definitions, warranties, exclusions, limits, provisions and conditions of this Section and of the Policy as a whole to indemnify the Insured against: All Risks of fortuitous and accidental physical loss or damage or destruction to the Property Insured occurring during the Period of Insurance, which results in Property Insured needing to be repaired or replaced, other than those specifically excluded:</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:loss_of_use_delay_or_loss_of_markets_or_consequential_loss_of_any_nature_whatsoever_or_any_costs_to_reduce_it_unless_covered_under_section_iii_of_the_policy_of_insurance" id="e:rel:17829863af2123a3">
  <data key="d26">SHALL_NOT_BE_LIABLE_FOR</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">(e) loss of use, delay or loss of markets or Consequential Loss of any nature whatsoever or any costs to reduce it unless covered under Section III of the Policy of Insurance</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insurer" target="ent:the_insured_against_accidental_physical_damage_to_machinery_and_or_equipment_insured_caused_by_an_accident_occurring_during_the_period_of_insurance" id="e:rel:9f46235cd76572d7">
  <data key="d26">AGREES_TO_INDEMNIFY</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insurer agrees subject to the terms, definitions, warranties, exclusions, limits, provisions and conditions of this Section and of the Policy of Insurance as a whole to indemnify the Insured against accidental physical damage to machinery and/or equipment insured caused by an Accident occurring during the Period of Insurance, which results in such machinery and/or equipment insured needing to be repaired or replaced.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:the_insurer_with_all_relevant_details_and_information" id="e:rel:a3bf60ee0a05002d">
  <data key="d26">SHALL_PROVIDE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insured shall provide the Insurer with all relevant details and information.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:all_reasonable_precautions" id="e:rel:ba877e4d18523f04">
  <data key="d26">SHALL_TAKE_AT_HIS_OWN_EXPENSE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insured shall take at his own expense all reasonable precautions, maintain the property in a proper state of repair and comply with all reasonable recommendations made by The Insurer, to prevent loss of or damage to the Property Insured or any liability arising under this Policy of Insurance and comply with all relevant statutory requirements.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:the_property_in_a_proper_state_of_repair" id="e:rel:8cb73bd63a0c05c6">
  <data key="d26">SHALL_MAINTAIN</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insured shall take at his own expense all reasonable precautions, maintain the property in a proper state of repair and comply with all reasonable recommendations made by The Insurer, to prevent loss of or damage to the Property Insured or any liability arising under this Policy of Insurance and comply with all relevant statutory requirements.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:all_reasonable_recommendations_made_by_the_insurer" id="e:rel:7a7fb481e01660c2">
  <data key="d26">SHALL_COMPLY_WITH</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insured shall take at his own expense all reasonable precautions, maintain the property in a proper state of repair and comply with all reasonable recommendations made by The Insurer, to prevent loss of or damage to the Property Insured or any liability arising under this Policy of Insurance and comply with all relevant statutory requirements.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:all_relevant_statutory_requirements" id="e:rel:8574ac4bbd43a494">
  <data key="d26">SHALL_COMPLY_WITH</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insured shall take at his own expense all reasonable precautions, maintain the property in a proper state of repair and comply with all reasonable recommendations made by The Insurer, to prevent loss of or damage to the Property Insured or any liability arising under this Policy of Insurance and comply with all relevant statutory requirements.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:the_government_and_all_other_binding_regulations_in_force_concerning_the_working_of_the_property_insured" id="e:rel:5b07d8717458015e">
  <data key="d26">SHALL_FULLY_OBSERVE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">The Insured shall fully observe the government and all other binding regulations in force concerning the working of the Property Insured</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:the_machinery_is_under_the_supervision_of_competent_personnel" id="e:rel:e94e9069ed02c881">
  <data key="d26">SHALL_SEE_TO_IT_THAT</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">and shall see to it that the machinery is under the supervision of competent personnel.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:the_insured" target="ent:such_measures_as_may_be_reasonable_for_the_purpose_of_averting_or_minimising_such_loss_or_damage" id="e:rel:a4e24d389cae70ed">
  <data key="d26">SHALL_TAKE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
