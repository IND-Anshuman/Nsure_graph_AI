  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">Official recognized Authority (or as agreed between the Insurer and the Insured) will elect the moment from which each of the aforesaid periods of seventy two (72) hours shall be deemed to have commenced</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:liability_for_earthquake_losses_after_expiration" target="ent:the_earthquake_damage_occurs_prior_to_the_date_and_time_of_the_expiration_of_this_policy" id="e:rel:86e823aaa75b930a">
  <data key="d26">PROVIDED_THAT</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">provided that the earthquake damage occurs prior to the date and time of the expiration of this Policy.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:any_and_all_losses_caused_by_earthquake" target="ent:a_single_loss_hereunder" id="e:rel:a3930a9ab745687a">
  <data key="d26">SHALL_CONSTITUTE</data>
