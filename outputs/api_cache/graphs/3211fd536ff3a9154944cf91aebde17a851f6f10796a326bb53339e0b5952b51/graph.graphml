  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">Any and all losses caused by earthquake shall constitute a single loss hereunder provided that more that one earthquake shock occurring within any seventy two (72) hour period during the Period of Insurance of this Policy shall be deemed to be a single earthquake within the meaning thereof.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:more_than_one_earthquake_shock_occurring_within_any_seventy_two_72_hour_period_during_the_period_of_insurance_of_this_policy" target="ent:a_single_earthquake" id="e:rel:bd4287a8090097d5">
  <data key="d26">SHALL_BE_DEEMED_TO_BE</data>
  <data key="d36">0.98</data>
  <data key="d37">sent:tmp_1769774017427_Large_Risk_-_Policy_Wordings:0</data>
  <data key="d38">provided that more that one earthquake shock occurring within any seventy two (72) hour period during the Period of Insurance of this Policy shall be deemed to be a single earthquake within the meaning thereof.</data>
  <data key="d29">oneshot</data>
</edge>
<edge source="ent:liability_for_flood_losses_after_expiration" target="ent:the_first_windstorm_damage_occurs_prior_to_the_date_and_time_of_the_expiration_of_this_policy" id="e:rel:4da9a32c581209e2">
  <data key="d26">PROVIDED_THAT</data>
